@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold">
                <i class="bi bi-speedometer2 text-primary me-2"></i>Dashboard
            </h1>
            <p class="text-muted">Library Management System Overview</p>
        </div>
        <div class="text-end">
            <p class="text-muted mb-0">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</p>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card bg-primary text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title text-uppercase opacity-75">Total Books</h6>
                            <h2 class="display-5 fw-bold mb-0">@Model.TotalBooks</h2>
                        </div>
                        <i class="bi bi-book stat-icon"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a asp-controller="Books" asp-action="Index" class="text-white text-decoration-none">
                        <small>View all books <i class="bi bi-arrow-right"></i></small>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card stat-card bg-success text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title text-uppercase opacity-75">Total Members</h6>
                            <h2 class="display-5 fw-bold mb-0">@Model.TotalMembers</h2>
                        </div>
                        <i class="bi bi-people stat-icon"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a asp-controller="Members" asp-action="Index" class="text-white text-decoration-none">
                        <small>View all members <i class="bi bi-arrow-right"></i></small>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card stat-card bg-info text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title text-uppercase opacity-75">Active Loans</h6>
                            <h2 class="display-5 fw-bold mb-0">@Model.ActiveLoans</h2>
                        </div>
                        <i class="bi bi-arrow-left-right stat-icon"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a asp-controller="Loans" asp-action="Index" asp-route-status="Active" class="text-white text-decoration-none">
                        <small>View active loans <i class="bi bi-arrow-right"></i></small>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card stat-card bg-danger text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title text-uppercase opacity-75">Overdue Loans</h6>
                            <h2 class="display-5 fw-bold mb-0">@Model.OverdueLoans</h2>
                        </div>
                        <i class="bi bi-exclamation-triangle stat-icon"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a asp-controller="Loans" asp-action="Index" asp-route-status="Overdue" class="text-white text-decoration-none">
                        <small>View overdue loans <i class="bi bi-arrow-right"></i></small>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Second Row: Additional Stats -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <h6 class="text-muted text-uppercase">Total Loans</h6>
                    <h3 class="text-primary fw-bold">@Model.TotalLoans</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <h6 class="text-muted text-uppercase">Returned Loans</h6>
                    <h3 class="text-success fw-bold">@Model.ReturnedLoans</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <h6 class="text-muted text-uppercase">Total Fines</h6>
                    <h3 class="text-warning fw-bold">$@Model.TotalFines.ToString("F2")</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Overdue Reminders Section -->
    @if (Model.OverdueReminders.Any())
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card border-danger">
                    <div class="card-header bg-danger text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-bell-fill me-2"></i>
                            Overdue Reminders (@Model.OverdueReminders.Count)
                        </h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Member</th>
                                        <th>Book</th>
                                        <th>Due Date</th>
                                        <th>Days Late</th>
                                        <th>Fine</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var reminder in Model.OverdueReminders)
                                    {
                                        <tr>
                                            <td><i class="bi bi-person me-1 text-muted"></i>@reminder.MemberName</td>
                                            <td><i class="bi bi-book me-1 text-muted"></i>@reminder.BookTitle</td>
                                            <td>@reminder.DueDate.ToString("yyyy-MM-dd")</td>
                                            <td><span class="badge bg-danger">@reminder.DaysLate days</span></td>
                                            <td><span class="text-danger fw-bold">$@reminder.FineAmount.ToString("F2")</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Recent Loans & Overdue Loans -->
    <div class="row g-4">
        <!-- Recent Loans -->
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-clock-history me-2 text-primary"></i>Recent Loans</h5>
                    <a asp-controller="Loans" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Book</th>
                                    <th>Member</th>
                                    <th>Due Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var loan in Model.RecentLoans)
                                {
                                    <tr>
                                        <td>@(loan.Book?.Title ?? "N/A")</td>
                                        <td>@(loan.Member?.FullName ?? "N/A")</td>
                                        <td>@loan.DueDate.ToString("yyyy-MM-dd")</td>
                                        <td>
                                            <span class="badge @GetStatusBadgeClass(loan.Status)">@loan.Status</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Overdue Loans -->
        <div class="col-lg-6">
            <div class="card h-100 border-danger">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-danger">
                        <i class="bi bi-exclamation-triangle me-2"></i>Overdue Loans
                    </h5>
                    <a asp-controller="Loans" asp-action="Index" asp-route-status="Overdue" class="btn btn-sm btn-outline-danger">View All</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Book</th>
                                    <th>Member</th>
                                    <th>Due Date</th>
                                    <th>Fine</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var loan in Model.OverdueLoanList)
                                {
                                    <tr class="table-danger">
                                        <td>@(loan.Book?.Title ?? "N/A")</td>
                                        <td>@(loan.Member?.FullName ?? "N/A")</td>
                                        <td>@loan.DueDate.ToString("yyyy-MM-dd")</td>
                                        <td><span class="text-danger fw-bold">$@loan.FineAmount.ToString("F2")</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Active" => "bg-info",
            "Returned" => "bg-success",
            "Overdue" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}
