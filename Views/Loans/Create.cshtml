@model LoanViewModel

@{
    ViewData["Title"] = "New Loan";
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Loans</a></li>
            <li class="breadcrumb-item active">New Loan</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h3 class="mb-0"><i class="bi bi-plus-lg text-primary me-2"></i>Borrow Book</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="BookId" class="form-label"></label>
                            <select asp-for="BookId" asp-items="Model.BooksList" class="form-select">
                                <option value="">-- Select a Book --</option>
                            </select>
                            <span asp-validation-for="BookId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MemberId" class="form-label"></label>
                            <select asp-for="MemberId" asp-items="Model.MembersList" class="form-select">
                                <option value="">-- Select a Member --</option>
                            </select>
                            <span asp-validation-for="MemberId" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="BorrowDate" class="form-label"></label>
                                <input asp-for="BorrowDate" class="form-control" type="date" />
                                <span asp-validation-for="BorrowDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DueDate" class="form-label"></label>
                                <input asp-for="DueDate" class="form-control" type="date" />
                                <span asp-validation-for="DueDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg me-2"></i>Create Loan
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
