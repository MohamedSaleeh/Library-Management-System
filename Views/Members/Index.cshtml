@model IEnumerable<Member>

@{
    ViewData["Title"] = "Members";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold">
                <i class="bi bi-people text-primary me-2"></i>Members
            </h1>
            <p class="text-muted">Manage library members</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>Add Member
        </a>
    </div>

    <!-- Search -->
    <div class="card mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" name="search" class="form-control" placeholder="Search by name, email, or phone..." value="@ViewBag.CurrentSearch" />
                        <button type="submit" class="btn btn-primary">Search</button>
                    </div>
                </div>
                <div class="col-md-4">
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Members Table -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Registration</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var member in Model)
                        {
                            <tr>
                                <td>
                                    <i class="bi bi-person-circle text-primary me-2"></i>
                                    <strong>@member.FullName</strong>
                                </td>
                                <td><a href="mailto:@member.Email">@member.Email</a></td>
                                <td>@(member.PhoneNumber ?? "-")</td>
                                <td>@member.RegistrationDate.ToString("yyyy-MM-dd")</td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@member.Id" class="btn btn-sm btn-outline-info" title="Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@member.Id" class="btn btn-sm btn-outline-primary ms-1" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@member.Id" class="btn btn-sm btn-outline-danger ms-1" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @if (!Model.Any())
        {
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                <p class="text-muted mt-3">No members found.</p>
            </div>
        }
    </div>
</div>
