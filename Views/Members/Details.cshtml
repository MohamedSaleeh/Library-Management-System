@model Member

@{
    ViewData["Title"] = Model.FullName;
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Members</a></li>
            <li class="breadcrumb-item active">@Model.FullName</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <i class="bi bi-person-circle text-primary" style="font-size: 5rem;"></i>
                    <h4 class="mt-3">@Model.FullName</h4>
                    <p class="text-muted">Member since @Model.RegistrationDate.ToString("MMMM yyyy")</p>
                </div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        <i class="bi bi-envelope me-2 text-muted"></i>@Model.Email
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-telephone me-2 text-muted"></i>@(Model.PhoneNumber ?? "Not provided")
                    </li>
                    <li class="list-group-item">
                        <i class="bi bi-geo-alt me-2 text-muted"></i>@(Model.Address ?? "Not provided")
                    </li>
                </ul>
                <div class="card-footer bg-white">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary w-100">
                        <i class="bi bi-pencil me-2"></i>Edit Member
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Loan History</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Book</th>
                                    <th>Borrowed</th>
                                    <th>Due</th>
                                    <th>Returned</th>
                                    <th>Status</th>
                                    <th>Fine</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var loan in Model.Loans.OrderByDescending(l => l.BorrowDate))
                                {
                                    <tr>
                                        <td>@(loan.Book?.Title ?? "N/A")</td>
                                        <td>@loan.BorrowDate.ToString("yyyy-MM-dd")</td>
                                        <td>@loan.DueDate.ToString("yyyy-MM-dd")</td>
                                        <td>@(loan.ReturnDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                        <td>
                                            <span class="badge @GetStatusBadge(loan.Status)">@loan.Status</span>
                                        </td>
                                        <td>
                                            @if (loan.FineAmount > 0)
                                            {
                                                <span class="text-danger fw-bold">$@loan.FineAmount.ToString("F2")</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (!Model.Loans.Any())
                    {
                        <div class="card-body text-center py-5 text-muted">
                            <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                            <p class="mt-2">No loan history</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Statistics -->
            <div class="row g-3 mt-1">
                <div class="col-md-4">
                    <div class="card text-center">
                        <div class="card-body">
                            <h4 class="text-primary">@Model.Loans.Count(l => l.Status == LoanStatus.Active)</h4>
                            <small class="text-muted">Active Loans</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center">
                        <div class="card-body">
                            <h4 class="text-success">@Model.Loans.Count(l => l.Status == LoanStatus.Returned)</h4>
                            <small class="text-muted">Returned</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center">
                        <div class="card-body">
                            <h4 class="text-danger">@Model.Loans.Count(l => l.Status == LoanStatus.Overdue)</h4>
                            <small class="text-muted">Overdue</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetStatusBadge(string status)
    {
        return status switch
        {
            "Active" => "bg-info",
            "Returned" => "bg-success",
            "Overdue" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}
