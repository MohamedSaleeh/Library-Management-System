@model Book

@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Books</a></li>
            <li class="breadcrumb-item active">@Model.Title</li>
        </ol>
    </nav>

    <div class="row g-4">
        <!-- Book Details -->
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h3 class="mb-0"><i class="bi bi-book text-primary me-2"></i>@Model.Title</h3>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Author</dt>
                        <dd class="col-sm-9">@Model.Author</dd>

                        <dt class="col-sm-3">ISBN</dt>
                        <dd class="col-sm-9"><code>@Model.ISBN</code></dd>

                        <dt class="col-sm-3">Category</dt>
                        <dd class="col-sm-9">
                            @if (!string.IsNullOrEmpty(Model.Category))
                            {
                                <span class="badge bg-secondary">@Model.Category</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </dd>

                        <dt class="col-sm-3">Published Year</dt>
                        <dd class="col-sm-9">@Model.PublishedYear</dd>

                        <dt class="col-sm-3">Available Quantity</dt>
                        <dd class="col-sm-9">
                            @if (Model.QuantityAvailable > 0)
                            {
                                <span class="badge bg-success fs-6">@Model.QuantityAvailable available</span>
                            }
                            else
                            {
                                <span class="badge bg-danger fs-6">Out of stock</span>
                            }
                        </dd>
                    </dl>
                </div>
                <div class="card-footer bg-white">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Back to List
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary ms-2">
                            <i class="bi bi-pencil me-2"></i>Edit
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Loan History -->
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Loan History</h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var loan in Model.Loans.OrderByDescending(l => l.BorrowDate))
                        {
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <small class="text-muted">@(loan.Member?.FullName ?? "Unknown")</small>
                                        <br />
                                        <small class="text-muted">@loan.BorrowDate.ToString("yyyy-MM-dd") - @(loan.ReturnDate?.ToString("yyyy-MM-dd") ?? "Not returned")</small>
                                    </div>
                                    <span class="badge @GetStatusBadge(loan.Status)">@loan.Status</span>
                                </div>
                            </div>
                        }
                        @if (!Model.Loans.Any())
                        {
                            <div class="list-group-item text-center text-muted py-4">
                                <i class="bi bi-inbox"></i> No loan history
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetStatusBadge(string status)
    {
        return status switch
        {
            "Active" => "bg-info",
            "Returned" => "bg-success",
            "Overdue" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}
